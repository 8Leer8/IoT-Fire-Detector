{
  "expo": {
    "name": "ESP32 Fire Detection",
    "slug": "firedetect-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "firedetectapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "usesCleartextTraffic": true,
      "googleServicesFile": "./google-services.json",
      "package": "com.mards.firedetectapp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF453A",
          "defaultChannel": "default",
          "sounds": [
            "./assets/sounds/mixkit_urgent_simple_tone_loop_2976.wav",
            "./assets/sounds/mixkit_access_allowed_tone_2869.wav",
            "./assets/sounds/mixkit_bell_notification_933.wav",
            "./assets/sounds/mixkit_clear_announce_tones_2861.wav",
            "./assets/sounds/mixkit_game_notification_wave_alarm_987.wav",
            "./assets/sounds/mixkit_happy_bells_notification_937.wav"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiUrl": "http://192.168.254.120:8000",
      "router": {},
      "eas": {
        "projectId": "ff51d20c-f7f4-4dc7-8543-8c9cd468d53c"
      }
    },
    "owner": "mards"
  }
}
